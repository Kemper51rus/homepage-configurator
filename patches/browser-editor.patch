diff --git a/scripts/browser-editor-mod.mjs b/scripts/browser-editor-mod.mjs
new file mode 100644
index 00000000..cb690a96
--- /dev/null
+++ b/scripts/browser-editor-mod.mjs
@@ -0,0 +1,91 @@
+import { execFileSync } from "child_process";
+import { existsSync, readFileSync, writeFileSync } from "fs";
+import { join } from "path";
+
+const envPath = join(process.cwd(), ".env.local");
+const patchPath = join(process.cwd(), "patches", "browser-editor.patch");
+const key = "HOMEPAGE_BROWSER_EDITOR";
+const command = process.argv[2] ?? "status";
+const modPaths = [
+  "next.config.js",
+  "package.json",
+  "scripts/browser-editor-mod.mjs",
+  "src/mods/browser-editor",
+  "src/pages/index.jsx",
+  "src/pages/api/config/editor.js",
+  "src/pages/api/config/background.js",
+  "src/components/services/item.jsx",
+  "src/components/services/list.jsx",
+  "src/components/bookmarks/group.jsx",
+  "src/components/bookmarks/item.jsx",
+  "src/components/bookmarks/list.jsx",
+];
+
+function readEnv() {
+  if (!existsSync(envPath)) return [];
+  return readFileSync(envPath, "utf8").split(/\r?\n/);
+}
+
+function writeEnv(lines) {
+  writeFileSync(envPath, `${lines.filter((line, index, all) => line.length || index < all.length - 1).join("\n")}\n`);
+}
+
+function setValue(value) {
+  const lines = readEnv();
+  const nextLine = `${key}=${value}`;
+  const index = lines.findIndex((line) => line.startsWith(`${key}=`));
+
+  if (index >= 0) {
+    lines[index] = nextLine;
+  } else {
+    lines.push(nextLine);
+  }
+
+  writeEnv(lines);
+  console.log(`${key}=${value} written to ${envPath}`);
+}
+
+function status() {
+  const line = readEnv().find((candidate) => candidate.startsWith(`${key}=`));
+  console.log(line ?? `${key} is not set in ${envPath}`);
+}
+
+function git(args, options = {}) {
+  return execFileSync("git", ["-c", `safe.directory=${process.cwd()}`, ...args], {
+    cwd: process.cwd(),
+    encoding: "utf8",
+    stdio: options.stdio ?? "pipe",
+  });
+}
+
+function createPatch() {
+  git(["add", "-N", ...modPaths], { stdio: "ignore" });
+  const patch = git(["diff", "--binary", "--", ...modPaths]);
+  writeFileSync(patchPath, patch);
+  console.log(`Patch written to ${patchPath}`);
+}
+
+function applyPatch() {
+  git(["apply", "--3way", patchPath], { stdio: "inherit" });
+}
+
+switch (command) {
+  case "enable":
+    setValue("true");
+    break;
+  case "disable":
+    setValue("false");
+    break;
+  case "status":
+    status();
+    break;
+  case "create-patch":
+    createPatch();
+    break;
+  case "apply-patch":
+    applyPatch();
+    break;
+  default:
+    console.error("Usage: node scripts/browser-editor-mod.mjs <enable|disable|status|create-patch|apply-patch>");
+    process.exit(1);
+}
